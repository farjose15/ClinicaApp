@model IEnumerable<ClinicaApp.Models.Historia_Clinica>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.fecha_consulta)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.sintomas)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.diagnostico)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.tratamiento)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.observaciones)
