@model IEnumerable<ClinicaApp.Models.Detalle_Receta>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>

<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.FirstOrDefault().cantidad)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FirstOrDefault().Medicamentos.nombre_medicamento)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FirstOrDefault().Recetas.indicaciones)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.cantidad)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Medicamentos.nombre_medicamento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Recetas.indicaciones)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.id_detalle }) |
                @Html.ActionLink("Details", "Details", new { id = item.id_detalle }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.id_detalle })
            </td>
        </tr>
    }

</table>